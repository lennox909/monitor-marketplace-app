<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FB">

    <TextView
        android:id="@+id/tvAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1F2A44"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage users and monitor marketplace activity"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnRefreshUsers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refresh Users"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F97316"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/lvUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#D1D5DB"
        android:dividerHeight="10dp" />

    <Button
        android:id="@+id/btnAdminLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#1F2A44"
        android:backgroundTint="#E5E7EB"
        android:layout_marginTop="12dp" />

</LinearLayout>