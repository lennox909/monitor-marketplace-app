<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monitor Title"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1F2A44" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$220.00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F97316"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brand: Dell"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:id="@+id/tvSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Size: 27 inch"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvResolution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resolution: 1920x1080"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvRefreshRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refresh Rate: 144Hz"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvCourseTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course Tag: CSE 3310"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category: Programming"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Condition: Used"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:layout_marginTop="18dp" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Detailed description here"
                    android:textSize="15sp"
                    android:textColor="#4B5563"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add to Cart"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#F97316"
                    android:layout_marginTop="22dp" />

                <Button
                    android:id="@+id/btnSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#1F2A44"
                    android:backgroundTint="#E5E7EB"
                    android:layout_marginTop="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>